(* generate_references.wls
   Reference data for the jlegroup Python `shadowmap` module, generated by the
   ORIGINAL Mathematica implementation:

       jleGroup`shadowMap`   4.1.4  (shadowMap_4.1.4.m, 2013-11-20)
       jleGroup`timeAndCoords` 7.5.6 (its real dependency)

   loaded from the installed package tree
   /Applications/Wolfram.app/Contents/AddOns/ExtraPackages/jleGroup (read-only).

   Run:  wolframscript -file generate_references.wls <outdir>
*)

outdir = If[Length[$ScriptCommandLine] >= 2, $ScriptCommandLine[[2]],
    Directory[]];
If[! DirectoryQ[outdir], CreateDirectory[outdir]];
Print["Output directory: ", outdir];

AppendTo[$Path, "/Applications/Wolfram.app/Contents/AddOns/ExtraPackages"];
Quiet[Needs["jleGroup`"]];

(* Force-load shadowMap + timeAndCoords via an exported symbol reference. *)
dummy = jleGroup`shadowMap`smSunPosn["2000:01:01:12:00:00"];

num[x_] := ToString[CForm[N[x]]];
row[items_List] := StringRiffle[ToString /@ items, ","];
csv[fname_String, header_String, rows_List] := Module[{s},
    s = StringRiffle[Prepend[rows, header], "\n"] <> "\n";
    Export[FileNameJoin[{outdir, fname}], s, "Text"];
    Print["wrote ", fname, "  (", Length[rows], " rows)"]];

(* ---------------------------------------------------------------- tc table *)
dates = {
    "2015:06:29:16:55:00",
    "1988:03:20:07:30:00",
    "2026:12:21:23:59:59.5",
    "1971:08:06:07:17:04.8",
    "2050:01:01:00:00:00",
    "1990,1,0,0,0,0",
    "2000 1 1 12 0 0",
    "1997:03:13:03:20:00",
    "2003:07:01:10:00:00"};
tcRows = Table[
    Module[{mjd},
        mjd = jleGroup`timeAndCoords`tcDateTimeStringToMJD[d];
        row[{"\"" <> d <> "\"", num[mjd],
            num[jleGroup`timeAndCoords`tcGMST[mjd]]}]],
    {d, dates}];
csv["tc_dates.csv", "date,mjd,gmst_hours", tcRows];

ras = {"17:45:31.20", "05 12 00", "23:59:59.999", "12:00:00", "21:30:00",
    "00:00:00.001"};
raRows = Table[row[{"\"" <> r <> "\"",
    num[jleGroup`timeAndCoords`tcHMSstringToRadians[r]]}], {r, ras}];
csv["tc_ra.csv", "ra_string,radians", raRows];

decs = {"-22:28:45.5", "+67 30 00", "-00:30:00", "00:00:01", "-45:00:00",
    "67:30:00", "00:00:00"};
decRows = Table[row[{"\"" <> d <> "\"",
    num[jleGroup`timeAndCoords`tcDecStringToRadians[d]]}], {d, decs}];
csv["tc_dec.csv", "dec_string,radians", decRows];

(* --------------------------------------------------------------- sun table *)
sunRows = Flatten[Table[
    Module[{r},
        r = jleGroup`shadowMap`smSunPosn[d,
            jleGroup`options`opKepler -> k];
        row[{"\"" <> d <> "\"", If[k, 1, 0],
            num[r[[1, 1]]], num[r[[1, 2]]], num[r[[2, 1]]], num[r[[2, 2]]]}]],
    {d, dates[[1 ;; 5]]}, {k, {True, False}}]];
csv["sun_position.csv",
    "date,kepler,lat_deg,eclip_long_deg,ra_hours,dec_deg", sunRows];

(* one radians-mode row to pin the unit conventions *)
rRad = jleGroup`shadowMap`smSunPosn["2015:06:29:16:55:00",
    jleGroup`options`opRadians -> True];
csv["sun_position_radians.csv", "lat_rad,eclip_long_rad,ra_rad,dec_rad",
    {row[num /@ Flatten[rRad]]}];

(* ------------------------------------------------------------------ smDist *)
bd = {{0.5, 31.9}, {1.234, 4.58}, {0.05, 0.386}, {2.0, 45.0}};
distRows = Table[row[{num[p[[1]]], num[p[[2]]],
    num[jleGroup`shadowMap`smDist[p[[1]], p[[2]]]]}], {p, bd}];
csv["smdist.csv", "b_arcsec,d_au,dist_earth_radii", distRows];

(* ---------------------------------------------------------------- smOffset *)
offCases = {
    {False, False, "00 00 00.35", "-00 00 01.20"},
    {True,  False, "00 00 00.35", "-00 00 01.20"},
    {False, True,  "00 00 00.35", "-00 00 01.20"},
    {True,  True,  "00 00 00.35", "-00 00 01.20"},
    {False, False, "-00 00 00.28", "00 00 00.75"}};
offRows = Table[
    Module[{r},
        r = jleGroup`shadowMap`smOffset["17 45 31.20", "-22 28 45.5",
            c[[3]], c[[4]], 0.31, 157.5, "2015 06 29 16 55 00", 24.2, 31.9,
            jleGroup`options`opRetrograde -> c[[1]],
            jleGroup`options`opAddOffToStar -> c[[2]]];
        row[{If[c[[1]], 1, 0], If[c[[2]], 1, 0],
            "\"" <> c[[3]] <> "\"", "\"" <> c[[4]] <> "\"",
            "\"" <> r[[1]] <> "\"", "\"" <> r[[2]] <> "\"",
            "\"" <> r[[3]] <> "\"",
            num[jleGroup`timeAndCoords`tcHMSstringToRadians[r[[1]]]],
            num[jleGroup`timeAndCoords`tcDecStringToRadians[r[[2]]]],
            num[jleGroup`timeAndCoords`tcDateTimeStringToMJD[
                StringReplace[r[[3]], ":" -> " "]]],
            num[r[[4]]], num[r[[5]]]}]],
    {c, offCases}];
csv["smoffset.csv",
    "retrograde,addoff,ra_off,dec_off,ra_new,dec_new,dt_new," <>
    "ra_new_rad,dec_new_rad,dt_new_mjd,b_new_arcsec,pa_new_deg", offRows];

(* ----------------------------------------------------------- findDirection *)
angles = {0, 22.4, 22.5, 45, 90, 135, 180, 225, 270, 315, 337.5, 359,
    720.1, -45};
dirRows = Table[row[{num[a],
    "\"" <> jleGroup`shadowMap`findDirection[a] <> "\""}], {a, angles}];
csv["directions.csv", "angle_deg,direction", dirRows];

(* -------------------------------------------------- raw continent database *)
contRaw = jleGroup`shadowMap`continents /. Line[pts_] :> pts;
contRows = Flatten[Table[
    row[{i, j, contRaw[[i, j, 1]], contRaw[[i, j, 2]]}],
    {i, Length[contRaw]}, {j, Length[contRaw[[i]]]}]];
csv["continents_raw.csv", "line,point,lat_arcmin,lon_arcmin", contRows];

(* -------------------------------------------- initialshadow raw cap points *)
Do[Module[{cap},
    cap = jleGroup`shadowMap`initialshadow[h];
    csv["cap_h" <> ToString[h] <> ".csv", "lat_rad,long_rad",
        Table[row[num /@ p], {p, cap}]]],
    {h, {0, 18}}];

(* ------------------------------------------------------------- globe cases *)
globeCases = {
    {"G1", "17:45:31.20", "-22:28:45.5", "2015:06:29:16:55:00", 0,
        "orthographic", 0.42, 157.5, 0.18, 0.25},
    {"G2", "05:12:00", "+67 30 00", "1997:03:13:03:20:00", 18,
        "orthographic", -0.35, 63.0, 0.55, 0.1},
    {"G3", "12:00:00", "00:00:00", "1988:03:20:07:30:00", 0,
        "mercator", 1.6, 200.0, 0.2, 0.0},
    {"G4", "21:30:00", "-45:00:00", "2003:07:01:10:00:00", 6,
        "equirectangular", 0.3, 310.0, 1.5, 0.5}};

scalarRows = {};
Do[Module[{name, raS, decS, date, h, proj, di, ang, rad, perr,
        ra, dec, gst, sunra, sundec, sunlong, viewlong, viewlat,
        theta, phi, longS, latS, xx, yy, zz, rot1, rot2,
        shadowG, shadowPts, cont, contLines, tilted, tracks, trackLines,
        labels},
    {name, raS, decS, date, h, proj, di, ang, rad, perr} = gc;

    ra = jleGroup`timeAndCoords`tcHMSstringToRadians[raS];
    dec = jleGroup`timeAndCoords`tcDecStringToRadians[decS];
    gst = jleGroup`timeAndCoords`tcGMST[
        jleGroup`timeAndCoords`tcDateTimeStringToMJD[date]];
    {sunra, sundec} =
        jleGroup`shadowMap`smSunPosn[date][[2]];
    sunlong = (sunra - gst) 15;
    viewlong = N[((ra 12)/Pi - gst) 15];
    viewlat = N[dec/Degree];

    (* showShadow internals: rot1/rot2 exactly as in the package source *)
    theta = viewlong Degree; phi = viewlat Degree;
    longS = sunlong Degree; latS = sundec Degree;
    xx = jleGroup`shadowMap`ccos[Pi + longS - theta]*
            jleGroup`shadowMap`ccos[latS]*jleGroup`shadowMap`ccos[phi] +
        jleGroup`shadowMap`csin[latS]*jleGroup`shadowMap`csin[phi];
    yy = jleGroup`shadowMap`csin[Pi + longS - theta]*
        jleGroup`shadowMap`ccos[latS];
    zz = jleGroup`shadowMap`ccos[Pi + longS - theta]*
            jleGroup`shadowMap`ccos[latS]*jleGroup`shadowMap`csin[phi] +
        jleGroup`shadowMap`csin[latS]*jleGroup`shadowMap`ccos[phi];
    rot1 = N[ArcSin[zz]/Degree];
    rot2 = N[ArcTan[xx, yy]/Degree];

    AppendTo[scalarRows, row[{name, "\"" <> raS <> "\"",
        "\"" <> decS <> "\"", "\"" <> date <> "\"", num[h],
        proj, num[di], num[ang], num[rad], num[perr],
        num[ra], num[dec], num[gst], num[sunra], num[sundec],
        num[sunlong], num[viewlong], num[viewlat], num[rot1], num[rot2]}]];

    (* night-shadow polygon, via the real showShadow *)
    shadowG = jleGroup`shadowMap`showShadow[viewlong, viewlat, sunlong,
        sundec, h, proj];
    shadowPts = First[Cases[{shadowG}, Polygon[pts_] :> pts, Infinity]];
    csv[name <> "_shadow.csv", "x,y",
        Table[row[num /@ p], {p, shadowPts}]];

    (* pre-projection tilted night-cap boundary (view-frame lat', long'),
       for the physical terminator check *)
    tilted = Module[{alpha, beta, sinal, cosal, initshadow},
        alpha = N[Pi/2 - rot1 Degree]; beta = N[rot2 Degree];
        initshadow = jleGroup`shadowMap`initialshadow[h];
        sinal = jleGroup`shadowMap`csin[alpha];
        cosal = jleGroup`shadowMap`ccos[alpha];
        initshadow /. {x_Real | x_Integer, y_Real | y_Integer} :>
            {jleGroup`shadowMap`xshad[x, y, sinal, cosal],
             jleGroup`shadowMap`yshad[x, y, beta, sinal, cosal]}];
    csv[name <> "_cap_viewframe.csv", "lat_rad,long_rad",
        Table[row[num /@ p], {p, tilted}]];

    (* projected continents, via the real newcont *)
    cont = jleGroup`shadowMap`newcont[viewlat, -viewlong, proj];
    contLines = Cases[{cont}, Line[pts_] :> pts, Infinity];
    csv[name <> "_continents.csv", "line,point,x,y",
        Flatten[Table[row[{i, j, num[contLines[[i, j, 1]]],
            num[contLines[[i, j, 2]]]}],
            {i, Length[contLines]}, {j, Length[contLines[[i]]]}]]];

    (* track lines (fundamental-plane geometry; projection-independent) *)
    tracks = jleGroup`shadowMap`drawtracks[di, ang, rad, perr, False];
    trackLines = Cases[{tracks}, Line[pts_] :> pts, Infinity];
    (* order: near-edge; {center, far-edge} multiline; minus; plus *)
    labels = {"near", "centerfar", "minus", "plus"};
    csv[name <> "_tracks.csv", "line_label,segment,point,x,y",
        Flatten[Table[
            Module[{pts = trackLines[[i]], lbl = labels[[i]]},
                If[lbl === "centerfar",
                    Flatten[Table[row[{lbl, s, j, num[pts[[s, j, 1]]],
                        num[pts[[s, j, 2]]]}],
                        {s, Length[pts]}, {j, Length[pts[[s]]]}]],
                    Table[row[{lbl, 1, j, num[pts[[j, 1]]],
                        num[pts[[j, 2]]]}], {j, Length[pts]}]]],
            {i, Length[trackLines]}]]];
    ], {gc, globeCases}];

csv["globe_cases.csv",
    "case,ra_string,dec_string,date,horizon_angle_deg,projection," <>
    "dist,pa_deg,radius,pred_error,ra_rad,dec_rad,gst_hours,sun_ra_hours," <>
    "sun_dec_deg,sun_long_deg,view_long_deg,view_lat_deg,rot1_deg,rot2_deg",
    scalarRows];

(* ------------------------------------------------- mercator function check *)
mx = {-1.4, -0.7, 0.0, 0.3, 1.1, 1.5};
csv["mercator_func.csv", "lat_rad,y",
    Table[row[{num[x], num[jleGroup`shadowMap`mercatorFunc[x]]}], {x, mx}]];

Print["ALL DONE"];
